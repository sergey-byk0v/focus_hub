{
  "manifest_version": 3,
  "name": "Focus Hub",
  "version": "1.0.0",
  "description": "Focus tools: site reason blocker + audio modulator",
  "permissions": [
    "webNavigation",
    "storage",
    "tabCapture",
    "offscreen",
    "tabs",
    "notifications",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Focus Hub"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
